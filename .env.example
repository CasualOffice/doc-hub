# Casual Drive configuration — copy to .env and fill in.
# This file is the contract; do NOT commit a populated .env.

# ─── Origins ─────────────────────────────────────────────────────────────────
# App origin: SPA, JSON API, WOPI host endpoints.
DRIVE_APP_ORIGIN=https://drive.example.org
# User-content origin: serves /raw/{token} only. MUST differ from app origin in prod.
DRIVE_USERCONTENT_ORIGIN=https://usercontent-drive.example.org

# ─── Server ──────────────────────────────────────────────────────────────────
DRIVE_BIND=0.0.0.0:8080
DRIVE_BODY_LIMIT_MB=100
DRIVE_PROD=true
RUST_LOG=info,drive=debug

# ─── Secrets (32-byte base64; boot refuses anything shorter in prod) ─────────
DRIVE_SESSION_SECRET=
DRIVE_WOPI_HMAC_SECRET=
DRIVE_SIGNED_URL_HMAC_SECRET=

# ─── Admin (single-tenant v0) ────────────────────────────────────────────────
DRIVE_ADMIN_USER=admin
# Generate with: argon2 yoursalt -id -t 2 -m 14 -p 1 -e
DRIVE_ADMIN_PASSWORD_HASH=

# ─── Storage backend (one of: fs | memory | s3 | minio) ──────────────────────
DRIVE_BACKEND=fs

# fs adapter
DRIVE_FS_ROOT=/var/lib/drive/data

# s3 / minio adapter (set DRIVE_S3_ENDPOINT for MinIO)
DRIVE_S3_BUCKET=
DRIVE_S3_REGION=us-east-1
DRIVE_S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Database (sqlite default; postgres for production) ──────────────────────
DRIVE_DB_URL=sqlite:///var/lib/drive/drive.db
# DRIVE_DB_URL=postgres://drive:drive@localhost:5432/drive

# ─── Antivirus (optional; ClamAV via Unix socket) ────────────────────────────
# DRIVE_ANTIVIRUS=clamd
# DRIVE_CLAMD_SOCKET=/var/run/clamav/clamd.ctl

# ─── Recipient share page footer (operator may disable) ──────────────────────
DRIVE_RECIPIENT_FOOTER=true
