---
/**
 * Doc-Hub mark — an ink rounded square holding a stack of versioned
 * documents (the registry motif). Source of truth: logo.svg (repo root)
 * + web/src/components/Logo.tsx + web/public/favicon.svg.
 * The square uses `currentColor`; the document stack uses `--mark-fg`
 * (defaults to the brand paper cream) so callers can recolour either
 * independently. The current sheet's text lines track `currentColor`.
 */
export interface Props {
  size?: number;
  className?: string;
}
const { size = 32, className } = Astro.props;
const clipId = `dh-mark-${Math.floor(Math.random() * 1e9).toString(36)}`;
---

<svg
  viewBox="0 0 38 38"
  width={size}
  height={size}
  role="img"
  aria-label="Doc-Hub"
  class={className}
  style={{ display: "block", color: "var(--ink)" }}
>
  <defs>
    <clipPath id={clipId}>
      <rect width="38" height="38" rx="10"></rect>
    </clipPath>
  </defs>
  <g clip-path={`url(#${clipId})`}>
    <rect width="38" height="38" fill="currentColor"></rect>
    <g fill="var(--mark-fg, var(--paper, #F5F3EE))">
      <rect x="15" y="6" width="15" height="18" rx="2.5" fill-opacity="0.4"></rect>
      <rect x="12" y="8.5" width="15" height="18" rx="2.5" fill-opacity="0.68"></rect>
      <rect x="9" y="11" width="15" height="18" rx="2.5"></rect>
    </g>
    <g fill="currentColor">
      <rect x="11.5" y="16" width="10" height="1.6" rx="0.8"></rect>
      <rect x="11.5" y="19.5" width="10" height="1.6" rx="0.8"></rect>
      <rect x="11.5" y="23" width="6.5" height="1.6" rx="0.8"></rect>
    </g>
  </g>
</svg>
