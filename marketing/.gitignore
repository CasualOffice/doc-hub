node_modules
dist
.astro
.env
.env.production
.DS_Store
# Lighthouse CI local report cache (HTML/JSON reports per run).
.lighthouseci

# Built SPA demo bundle — copied in at build time, never committed.
public/demo-app

# Self-hosted Inter fonts — fetched by CI from rsms.me. The .gitkeep
# tells the directory to exist; the woff2 files themselves are not
# checked in (binary blobs, kept fresh by the workflow).
public/fonts/*.woff2

# Optimized image variants generated by scripts/optimize-screenshots.mjs
# from the source PNGs in public/screenshots/. Always regenerated on
# `pnpm build` so they stay in lockstep with the PNGs.
public/screenshots/*.avif
public/screenshots/*.webp
